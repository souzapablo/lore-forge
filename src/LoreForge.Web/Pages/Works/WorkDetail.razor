@page "/works/{Id:guid}"

<PageTitle>@(_work?.Title ?? "Obra") — Lore Forge</PageTitle>

@if (_loading)
{
    <div class="loading-state">
        <span class="loading-spinner">◌</span> Carregando obra…
    </div>
}
else if (_notFound)
{
    <div class="empty-state">
        <div class="empty-state-sigil">◈</div>
        <div class="empty-state-title">Obra não encontrada</div>
        <div class="empty-state-sub">
            <button class="btn btn-ghost" @onclick='() => Nav.NavigateTo("/works")'>← Voltar para obras</button>
        </div>
    </div>
}
else if (_work is not null)
{
    <div class="page-header">
        <div class="page-header-text">
            <div class="work-detail-breadcrumb">
                <button class="btn btn-ghost btn-sm" @onclick='() => Nav.NavigateTo("/works")'>← Obras</button>
            </div>
            @if (_editing)
            {
                <div class="work-detail-title-row">
                    <div class="work-type-dot @DotClass(_work.Type)"></div>
                    <input class="field-input field-title" @bind="_form.Title" placeholder="Título" />
                </div>
                <div class="work-detail-meta">
                    <span class="work-type-label">@TypeLabel(_work.Type)</span>
                </div>
            }
            else
            {
                <div class="work-detail-title-row">
                    <div class="work-type-dot @DotClass(_work.Type)"></div>
                    <h1>@_work.Title</h1>
                    <span class="work-status @StatusClass(_work.Status)">@StatusLabel(_work.Status)</span>
                </div>
                <div class="work-detail-meta">
                    <span class="work-type-label">@TypeLabel(_work.Type)</span>
                    @if (_work.Genres.Length > 0)
                    {
                        <span class="meta-sep">·</span>
                        @string.Join(", ", _work.Genres)
                    }
                </div>
            }
        </div>
        <div class="page-header-actions">
            @if (_editing)
            {
                <button class="btn btn-ghost" @onclick="CancelEdit">Cancelar</button>
                <button class="btn btn-gold" @onclick="SaveAsync" disabled="@_saving">
                    @(_saving ? "Salvando…" : "Salvar")
                </button>
            }
            else
            {
                <button class="btn btn-ghost" @onclick="StartEdit">Alterar</button>
            }
        </div>
    </div>

    @if (!string.IsNullOrEmpty(_errorMessage))
    {
        <div class="field-error-banner">@_errorMessage</div>
    }

    <div class="page-content">
        @if (_editing)
        {
            <div class="edit-meta-row">
                <div class="field-group">
                    <label class="field-label">Status</label>
                    <select class="field-select" @bind="_form.Status">
                        @foreach (var status in Enum.GetValues<WorkStatus>())
                        {
                            <option value="@status">@StatusLabel(status)</option>
                        }
                    </select>
                </div>
                <div class="field-group">
                    <label class="field-label">Gêneros <span class="field-hint">(separados por vírgula)</span></label>
                    <input class="field-input" @bind="_form.Genres" placeholder="rpg, ação, fantasia" />
                </div>
                <div class="field-group">
                    <label class="field-label">Tags <span class="field-hint">(separadas por vírgula)</span></label>
                    <input class="field-input" @bind="_form.Tags" placeholder="fromsoft, favorito" />
                </div>
            </div>

            <div class="notes-grid">
                <div class="note-card">
                    <label class="note-card-label">Worldbuilding</label>
                    <textarea class="field-textarea" @bind="_form.Worldbuilding" placeholder="Notas sobre o mundo…"></textarea>
                </div>
                <div class="note-card">
                    <label class="note-card-label">Magia</label>
                    <textarea class="field-textarea" @bind="_form.Magic" placeholder="Sistema de magia, poderes…"></textarea>
                </div>
                <div class="note-card">
                    <label class="note-card-label">Personagens</label>
                    <textarea class="field-textarea" @bind="_form.Characters" placeholder="Personagens marcantes…"></textarea>
                </div>
                <div class="note-card">
                    <label class="note-card-label">Temas</label>
                    <textarea class="field-textarea" @bind="_form.Themes" placeholder="Temas e ideias centrais…"></textarea>
                </div>
                <div class="note-card">
                    <label class="note-card-label">Estrutura narrativa</label>
                    <textarea class="field-textarea" @bind="_form.PlotStructure" placeholder="Como a história se estrutura…"></textarea>
                </div>
                <div class="note-card">
                    <label class="note-card-label">O que eu gostei</label>
                    <textarea class="field-textarea" @bind="_form.WhatILiked" placeholder="O que mais te marcou…"></textarea>
                </div>
            </div>
        }
        else
        {
            @if (_work.Tags.Length > 0)
            {
                <div class="work-tags" style="margin-bottom: 24px;">
                    @foreach (var tag in _work.Tags)
                    {
                        <span class="tag">@tag</span>
                    }
                </div>
            }

            <div class="notes-grid">
                @if (_work.Notes.Worldbuilding is not null)
                {
                    <div class="note-card">
                        <div class="note-card-label">Worldbuilding</div>
                        <div class="note-card-body">@_work.Notes.Worldbuilding</div>
                    </div>
                }
                @if (_work.Notes.Magic is not null)
                {
                    <div class="note-card">
                        <div class="note-card-label">Magia</div>
                        <div class="note-card-body">@_work.Notes.Magic</div>
                    </div>
                }
                @if (_work.Notes.Characters is not null)
                {
                    <div class="note-card">
                        <div class="note-card-label">Personagens</div>
                        <div class="note-card-body">@_work.Notes.Characters</div>
                    </div>
                }
                @if (_work.Notes.Themes is not null)
                {
                    <div class="note-card">
                        <div class="note-card-label">Temas</div>
                        <div class="note-card-body">@_work.Notes.Themes</div>
                    </div>
                }
                @if (_work.Notes.PlotStructure is not null)
                {
                    <div class="note-card">
                        <div class="note-card-label">Estrutura narrativa</div>
                        <div class="note-card-body">@_work.Notes.PlotStructure</div>
                    </div>
                }
                @if (_work.Notes.WhatILiked is not null)
                {
                    <div class="note-card">
                        <div class="note-card-label">O que eu gostei</div>
                        <div class="note-card-body">@_work.Notes.WhatILiked</div>
                    </div>
                }
            </div>
        }
    </div>
}
