@page "/works"

<PageTitle>Obras — Lore Forge</PageTitle>

<div class="page-header">
    <div class="page-header-text">
        <h1>Obras</h1>
        <p>Jogos, livros, filmes e séries do seu diário</p>
    </div>
    <div class="page-header-actions">
        <button class="btn btn-gold" @onclick="OpenAddModal">+ Adicionar obra</button>
    </div>
</div>

<div class="filter-bar">
    <span class="filter-label">Tipo</span>
    @foreach (var type in Enum.GetValues<WorkType>())
    {
        <button class="btn btn-ghost @(SelectedTypes.Contains(type) ? "active" : "")"
                @onclick="() => ToggleType(type)">
            @TypeLabel(type)
        </button>
    }
    <div style="width: 1px; height: 18px; background: var(--border-bright); margin: 0 4px;"></div>
    <span class="filter-label">Status</span>
    @foreach (var status in Enum.GetValues<WorkStatus>())
    {
        <button class="btn btn-ghost @(SelectedStatuses.Contains(status) ? "active" : "")"
                @onclick="() => ToggleStatus(status)">
            @StatusLabel(status)
        </button>
    }
</div>

@if (_showAddModal)
{
    <div class="modal-overlay" @onclick="CloseAddModal">
        <div class="modal" @onclick:stopPropagation>
            <div class="modal-header">
                <span class="modal-title">Nova obra</span>
                <button class="modal-close" @onclick="CloseAddModal">✕</button>
            </div>
            <div class="modal-body">
                @if (!string.IsNullOrEmpty(_addErrorMessage))
                {
                    <div class="field-error-banner">@_addErrorMessage</div>
                }
                <div class="edit-meta-row">
                    <div class="field-group">
                        <label class="field-label">Título</label>
                        <input class="@AddTitleInputClass" @bind="_addForm.Title" placeholder="Nome da obra" />
                    </div>
                    <div class="field-group">
                        <label class="field-label">Tipo</label>
                        <select class="field-select" @bind="_addForm.Type">
                            @foreach (var type in Enum.GetValues<WorkType>())
                            {
                                <option value="@type">@TypeLabel(type)</option>
                            }
                        </select>
                    </div>
                    <div class="field-group">
                        <label class="field-label">Status</label>
                        <select class="field-select" @bind="_addForm.Status">
                            @foreach (var status in Enum.GetValues<WorkStatus>())
                            {
                                <option value="@status">@StatusLabel(status)</option>
                            }
                        </select>
                    </div>
                </div>
                <div class="edit-meta-row">
                    <div class="field-group">
                        <label class="field-label">Gêneros <span class="field-hint">(separados por vírgula)</span></label>
                        <input class="field-input" @bind="_addForm.Genres" placeholder="rpg, ação, fantasia" />
                    </div>
                    <div class="field-group">
                        <label class="field-label">Tags <span class="field-hint">(separadas por vírgula)</span></label>
                        <input class="field-input" @bind="_addForm.Tags" placeholder="fromsoft, favorito" />
                    </div>
                </div>
                <div class="@AddNotesGridClass">
                    <div class="note-card">
                        <label class="note-card-label">Worldbuilding</label>
                        <textarea class="field-textarea" @bind="_addForm.Worldbuilding" placeholder="Notas sobre o mundo…"></textarea>
                    </div>
                    <div class="note-card">
                        <label class="note-card-label">Magia</label>
                        <textarea class="field-textarea" @bind="_addForm.Magic" placeholder="Sistema de magia, poderes…"></textarea>
                    </div>
                    <div class="note-card">
                        <label class="note-card-label">Personagens</label>
                        <textarea class="field-textarea" @bind="_addForm.Characters" placeholder="Personagens marcantes…"></textarea>
                    </div>
                    <div class="note-card">
                        <label class="note-card-label">Temas</label>
                        <textarea class="field-textarea" @bind="_addForm.Themes" placeholder="Temas e ideias centrais…"></textarea>
                    </div>
                    <div class="note-card">
                        <label class="note-card-label">Estrutura narrativa</label>
                        <textarea class="field-textarea" @bind="_addForm.PlotStructure" placeholder="Como a história se estrutura…"></textarea>
                    </div>
                    <div class="note-card">
                        <label class="note-card-label">O que eu gostei</label>
                        <textarea class="field-textarea" @bind="_addForm.WhatILiked" placeholder="O que mais te marcou…"></textarea>
                    </div>
                </div>
            </div>
            <div class="modal-footer">
                <button class="btn btn-ghost" @onclick="CloseAddModal">Cancelar</button>
                <button class="btn btn-gold" @onclick="SaveAddAsync" disabled="@_addSaving">
                    @(_addSaving ? "Salvando…" : "Adicionar")
                </button>
            </div>
        </div>
    </div>
}

@if (_loading)
{
    <div class="loading-state">
        <span class="loading-spinner">◌</span> Carregando seu diário…
    </div>
}
else if (_result is null || _result.Items.Count == 0)
{
    <div class="empty-state">
        <div class="empty-state-sigil">◈</div>
        <div class="empty-state-title">Seu diário está vazio</div>
        <div class="empty-state-sub">Adicione a primeira obra para começar sua biblioteca de inspiração.</div>
    </div>
}
else
{
    <div class="page-content">
        <div class="works-grid">
            @foreach (var work in _result.Items)
            {
                <div class="work-card" @onclick="() => OpenWork(work.Id)">
                    <div class="work-card-header">
                        <div class="work-type-dot @DotClass(work.Type)"></div>
                        <span class="work-card-title">@work.Title</span>
                    </div>
                    <div class="work-card-meta">
                        <span class="work-type-label">@TypeLabel(work.Type)</span>
                        <span class="work-status @StatusClass(work.Status)">@StatusLabel(work.Status)</span>
                    </div>
                    @if (work.Tags.Length > 0)
                    {
                        <div class="work-tags">
                            @foreach (var tag in work.Tags)
                            {
                                <span class="tag">@tag</span>
                            }
                        </div>
                    }
                    <div class="work-card-actions" @onclick:stopPropagation>
                        @if (_confirmingDeleteId == work.Id)
                        {
                            <span class="delete-confirm-label">Excluir?</span>
                            <button class="btn btn-ghost btn-sm" @onclick="CancelDelete">Não</button>
                            <button class="btn btn-danger btn-sm" @onclick="() => ConfirmDeleteAsync(work.Id)">Sim</button>
                        }
                        else
                        {
                            <button class="btn btn-ghost btn-sm" @onclick="() => RequestDelete(work.Id)">Excluir</button>
                        }
                    </div>
                </div>
            }
        </div>
    </div>

    <div class="pagination-bar">
        <span class="pagination-info">
            @((_currentPage - 1) * PageSize + 1)–@Math.Min(_currentPage * PageSize, _result.TotalCount) de @_result.TotalCount obras
        </span>
        <div class="pagination-controls">
            <button class="btn btn-ghost" disabled="@(!_result.HasPreviousPage)" @onclick="PreviousPage">← Anterior</button>
            <button class="btn btn-ghost" disabled="@(!_result.HasNextPage)" @onclick="NextPage">Próxima →</button>
        </div>
    </div>
}
