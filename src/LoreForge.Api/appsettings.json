{
  "Serilog": {
    "Using": [ "Serilog.Sinks.Console", "Serilog.Sinks.File" ],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.AspNetCore": "Warning",
        "System": "Warning"
      }
    },
    "WriteTo": [
      {
        "Name": "Console",
        "Args": {
          "formatter": "Serilog.Formatting.Compact.CompactJsonFormatter, Serilog.Formatting.Compact"
        }
      },
      {
        "Name": "File",
        "Args": {
          "path": "logs/loreforge-.log",
          "rollingInterval": "Day",
          "formatter": "Serilog.Formatting.Compact.CompactJsonFormatter, Serilog.Formatting.Compact"
        }
      }
    ],
    "Enrich": [ "FromLogContext" ]
  },
  "AllowedHosts": "*",
  "WebBaseUrl": "http://localhost:5293",
  "Cors": {
    "AllowedOrigins": []
  },
  "ConnectionStrings": {
    "Postgres": ""
  },
  "Bedrock": {
    "AgentModelId": "amazon.nova-micro-v1:0",
    "EmbeddingModelId": "amazon.titan-embed-text-v2:0",
    "SystemPromptPath": "assets/prompts/system-prompt.txt",
    "ToolGuidancePaths": {
      "check_world_consistency": "assets/prompts/tools/check-world-consistency.txt",
      "suggest_character_arc": "assets/prompts/tools/suggest-character-arc.txt",
      "analyze_plot_structure": "assets/prompts/tools/analyze-plot-structure.txt",
      "find_thematic_connections": "assets/prompts/tools/find-thematic-connections.txt"
    }
  },
  "DynamoDB": {
    "TableName": "loreforge-conversations",
    "TtlDays": 30
  }
}
